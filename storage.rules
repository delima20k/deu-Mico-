rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPathOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Modo operacional imediato para audio do chat.
    // Permite acesso em qualquer subcaminho de /chat-audio apenas para usuarios autenticados.
    match /chat-audio/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // Nega qualquer outro caminho por padrao.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
