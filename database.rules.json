{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "lobbies": {
      "$lobbyType": {
        "queue": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        },
        "lock": {
          ".read":  "auth != null",
          ".write": "auth != null"
        },
        "startToken": {
          ".read":  "auth != null",
          ".write": "auth != null"
        },
        "assign": {
          ".read":  "auth != null",
          ".write": "auth != null"
        },
        "deadlineTs": {
          ".read":  "auth != null",
          ".write": "auth != null"
        },
        "lastJoinTs": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "matches": {
      "$matchId": {
        ".read": "auth != null && root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists()",
        "meta": {
          ".write": "auth != null && (root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists() || (!data.exists() && newData.child('players').hasChildren()))"
        },
        "state": {
          ".write": "auth != null && root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists()"
        },
        "presence": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        },
        "chat": {
          ".write": "auth != null && root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists()"
        },
        "chatPlayback": {
          ".write": "auth != null && root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists()"
        },
        "chatAudioCleanup": {
          ".write": "auth != null && root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists()"
        },
        "gameState": {
          ".write": "auth != null && root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists()"
        },
        "animations": {
          ".write": "auth != null && root.child('matches/' + $matchId + '/meta/players/' + auth.uid).exists()",
          ".indexOn": "ts"
        }
      }
    },
    "tournaments": {
      ".read": "auth != null",
      "list": {
        ".write": "auth != null"
      },
      "currentTournamentId": {
        ".write": "auth != null"
      },
      "instances": {
        ".write": "auth != null"
      },
      "currentJoinableInstanceId": {
        ".write": "auth != null"
      },
      "enrollmentIndex": {
        "$tournamentId": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      },
      "leaderboard": {
        ".write": "auth != null"
      }
    },
    "rankings": {
      ".read":  "auth != null",
      ".write": "auth != null"
    }
  }
}
